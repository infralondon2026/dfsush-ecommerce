# ============================================================
# DFSAS Tienda — variables de entorno
# Copiar a .env para desarrollo local. JAMÁS commitear .env.
# ============================================================

# --- Frontend (Vite; se exponen al navegador, solo claves PÚBLICAS) ---

# URL del proyecto Supabase (https://<ref>.supabase.co)
VITE_SUPABASE_URL=
# Anon key pública de Supabase (safe para el browser; RLS protege los datos)
VITE_SUPABASE_ANON_KEY=

# Modo demo: catálogo y órdenes en localStorage, checkout simulado.
# Se activa también automáticamente si faltan las variables de Supabase.
VITE_USE_DEMO_DATA=true

# Password del panel /equipo en modo demo. Si falta, el panel queda deshabilitado.
# Elegir un valor propio; no hay ninguna password por defecto.
VITE_ADMIN_DEMO_PASSWORD=

# --- Edge Functions (secrets de Supabase; configurar con `supabase secrets set`) ---
# JAMÁS poner estos valores en el frontend ni commitearlos.

# Access token PRIVADO de Mercado Pago (Checkout Pro)
MP_ACCESS_TOKEN=
# Moneda que se envía a Mercado Pago (cuentas de Argentina: ARS — ver README)
MP_CURRENCY_ID=USD
# API key de Resend para emails transaccionales
RESEND_API_KEY=
# Remitente verificado en Resend, p.ej. "DFSAS Tienda <tienda@tudominio.com>"
EMAIL_FROM=
# URL pública del sitio (para back_urls de MP y links en emails)
SITE_URL=
